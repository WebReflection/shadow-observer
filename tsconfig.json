{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "skipLibCheck": true,
    "stripInternal": true,
    "strict": false,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"]
  },
  "include": ["./index.js"],
  "exclude": ["node_modules", "types", "test"]
}
